# ──────────────────────────────────────────────────────────────────────────────
# Kovara web app — environment variables
# ──────────────────────────────────────────────────────────────────────────────
#
# SECURITY: every variable below uses the NEXT_PUBLIC_ prefix, which means the
# value is bundled into the client JavaScript and is therefore PUBLIC to anyone
# who visits the site. NEVER put real secrets here. Secrets (signing keys,
# database credentials, etc.) must live in server-only routes and use unprefixed
# variables that are not exposed to `process.env` in the browser.
#
# Create a local copy of this file named `.env.local` to set your own values:
#
#     cp .env.example .env.local        # development
#     cp .env.example .env.testnet      # (optional) shared testnet values
#
# `.env.local` and any `.env*.local` files are EXCLUDED from git by the Next.js
# convention. The defaults below match a testnet deployment — paste your own
# contract IDs and RPC URLs in `.env.local` to override.
# ──────────────────────────────────────────────────────────────────────────────


# ─── Stellar network ────────────────────────────────────────────────────────
# Which network the app talks to. Controls the default Horizon + Soroban RPC
# URLs when those are not set explicitly. Valid values: "testnet" | "mainnet".
NEXT_PUBLIC_STELLAR_NETWORK=testnet

# Stellar Horizon REST endpoint. Leave unset to use the network default
# (testnet → https://horizon-testnet.stellar.org, mainnet → https://horizon.stellar.org).
# Set this when running against a local Stellar quickstart or other RPC mirror.
# NEXT_PUBLIC_HORIZON_URL=https://horizon-testnet.stellar.org

# Soroban JSON-RPC endpoint used for contract calls. Leave unset to use the
# network default (testnet → https://soroban-testnet.stellar.org,
# mainnet → https://soroban-rpc.stellar.org).
# NEXT_PUBLIC_SOROBAN_RPC_URL=https://soroban-testnet.stellar.org


# ─── Kovara smart-contract addresses (REQUIRED) ─────────────────────────────
# Address of each deployed Kovara Soroban contract on the target network.
# Get these from `scripts/deploy_testnet.sh` after deploying, or from the
# Kovara deployer output. The four contracts below MUST all be set or the
# app will fail to start with `[config] Missing required environment variable`.
NEXT_PUBLIC_PRICE_VAULT_CONTRACT_ID=
NEXT_PUBLIC_FLOW_REWARDS_CONTRACT_ID=
NEXT_PUBLIC_SENTINEL_POOL_CONTRACT_ID=
NEXT_PUBLIC_KOVARA_INDEX_CONTRACT_ID=


# ─── Pools page tuning (OPTIONAL) ──────────────────────────────────────────
# Default XLM tip amount shown on pools/[id], in stroops (1 XLM = 10_000_000).
NEXT_PUBLIC_DEFAULT_TIP_AMOUNT_STROOPS=500000

# Maximum number of pool entries rendered before pagination kicks in.
NEXT_PUBLIC_POOL_PAGE_ENTRY_LIMIT=50


# ─── Kovara public API (OPTIONAL) ──────────────────────────────────────────
# Base URL for the Kovara REST API. Leave unset to use the production host.
# NEXT_PUBLIC_API_BASE_URL=https://api.kovara.io/v1

# Base URL for the Kovara GraphQL endpoint.
# NEXT_PUBLIC_GRAPHQL_URL=https://api.kovara.io/graphql


# ─── Feature flags (OPTIONAL) ──────────────────────────────────────────────
# Set to "true" to enable the experimental verifier voting UI. Anything other
# than the literal string "true" is treated as disabled.
NEXT_PUBLIC_FEATURE_VERIFY_QUEUE=false


# ──────────────────────────────────────────────────────────────────────────────
# Local development tip
# ──────────────────────────────────────────────────────────────────────────────
#
# When you fork Kovara and run it against a Stellar quickstart sandbox, set:
#
#   NEXT_PUBLIC_STELLAR_NETWORK=testnet
#   NEXT_PUBLIC_HORIZON_URL=http://localhost:8000
#   NEXT_PUBLIC_SOROBAN_RPC_URL=http://localhost:8000/soroban/rpc
#   NEXT_PUBLIC_NETWORK_PASSPHRASE="Standalone Network ; February 2017"
#   NEXT_PUBLIC_PRICE_VAULT_CONTRACT_ID=<from deploy_testnet.sh>
#   NEXT_PUBLIC_FLOW_REWARDS_CONTRACT_ID=<from deploy_testnet.sh>
#   NEXT_PUBLIC_SENTINEL_POOL_CONTRACT_ID=<from deploy_testnet.sh>
#   NEXT_PUBLIC_KOVARA_INDEX_CONTRACT_ID=<from deploy_testnet.sh>
#
# CI (see .github/workflows/frontend-e2e.yml) does this with $GITHUB_ENV
# exports so test PRs never depend on a developer-local .env file.
