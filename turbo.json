{
  "$schema": "https://turbo.build/schema.json",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**", "target/**", ".next/**", ".expo/**"]
    },
    "dev": { 
      "persistent": true, 
      "cache": false 
    },
    "lint": {
      "dependsOn": ["^build"]
    },
    "test": {
      "dependsOn": ["^build"]
    },
    "test:integration": {
      "cache": false
    },
    "format": {
      "outputs": []
    }
  }
}
